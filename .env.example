# JWT 签名密钥（必填，至少 32 字符）
JWT_SECRET=your-32-character-secret-key-here

# 认证模式：auto（默认）/ tof / jwt
# auto = 自动检测（推荐）
AUTH_MODE=auto

# ============================================================
# 太湖鉴权配置（TOF 统一登录）
# ============================================================
# 太湖应用 Token（32位字符串，用于解密 x-tai-identity）
# 在太湖平台 (tai.it.woa.com) → 应用概览 中获取
TAI_APP_TOKEN=your-tai-app-token

# 太湖应用 PAAS ID
TAI_PAAS_ID=strategicsouth

# TOF 白名单（逗号分隔，留空则不限制）
# 仅允许以下用户登录（英文名）
TOF_ALLOWED_USERS=anniexzhang,adamyide,blackyzhang,cherylzshen,dinghaoyang,ethanmhua,mercuryyan,shixu,wayynewang,zyfeizhang
