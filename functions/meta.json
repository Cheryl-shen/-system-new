{
  "functions": [
    {
      "path": "/api/auth/login",
      "method": ["POST"],
      "description": "用户登录（账密）"
    },
    {
      "path": "/api/auth/logout",
      "method": ["POST"],
      "description": "用户登出"
    },
    {
      "path": "/api/auth/me",
      "method": ["GET"],
      "description": "获取当前登录用户信息"
    },
    {
      "path": "/api/auth/check",
      "method": ["GET"],
      "description": "检查认证状态和登录确认状态"
    },
    {
      "path": "/api/auth/confirm",
      "method": ["POST"],
      "description": "确认登录"
    },
    {
      "path": "/api/auth/tof/check",
      "method": ["GET"],
      "description": "检查 TOF 登录状态"
    },
    {
      "path": "/api/admin/users",
      "method": ["GET"],
      "description": "用户列表（仅管理员）"
    },
    {
      "path": "/api/admin/users/:username/role",
      "method": ["PUT"],
      "description": "修改用户角色（仅管理员）"
    },
    {
      "path": "/api/admin/users/:username/status",
      "method": ["PUT"],
      "description": "启用/禁用用户（仅管理员）"
    },
    {
      "path": "/api/admin/login-logs",
      "method": ["GET"],
      "description": "登录日志（仅管理员）"
    },
    {
      "path": "/api/admin/init",
      "method": ["POST"],
      "description": "初始化管理员账号"
    }
  ]
}
